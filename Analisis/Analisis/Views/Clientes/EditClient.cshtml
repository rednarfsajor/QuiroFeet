@model Analisis.BD.Clientes

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.Title = "Editar Cliente";
}

<div class="container" style="font-family: 'Poppins', sans-serif;">
    <h1 class="text-center">Editar Cliente</h1>
    <p class="text-center">Modifica la información del cliente</p>

    @using (Html.BeginForm("EditClient", "Clientes", FormMethod.Post))
    {
        @Html.AntiForgeryToken()
        @Html.HiddenFor(model => model.id)

        <!-- Nombre -->
        <label for="nombre">Nombre</label>
        @Html.TextBoxFor(model => model.nombre, new { @class = "form-control", placeholder = "Ingrese el nombre", required = "required" })
        @Html.ValidationMessageFor(model => model.nombre)

        <!-- Correo -->
        <label for="correo">Correo Electrónico</label>
        @Html.TextBoxFor(model => model.correo, new { @class = "form-control", placeholder = "Ingrese el correo electrónico", type = "email", required = "required" })
        @Html.ValidationMessageFor(model => model.correo)

        <!-- Teléfono -->
        <label for="telefono">Teléfono</label>
        @Html.TextBoxFor(model => model.telefono, new
        {
            @class = "form-control",
            placeholder = "Ingrese el número de teléfono",
            pattern = "\\d{8}",
            title = "Debe contener 8 dígitos"
        })
        @Html.ValidationMessageFor(model => model.telefono)

        <!-- Botones -->
        <div class="text-center mt-4">
            <button type="submit" class="btn btn-save">Guardar Cambios</button>
            <a href="@Url.Action("ListClients", "Clientes")" class="btn btn-cancel">Cancelar</a>
        </div>
    }
</div>

<style>
    .container {
        max-width: 600px;
        margin: 50px auto;
        background-color: #ffffff;
        padding: 40px;
        border-radius: 12px;
        box-shadow: 0 8px 16px rgba(0, 0, 0, 0.1);
    }

    h1 {
        color: #234449;
        margin-bottom: 10px;
    }

    label {
        display: block;
        margin-top: 20px;
        font-weight: bold;
    }

    input {
        width: 100%;
        padding: 12px;
        margin-top: 8px;
        margin-bottom: 20px;
        border: 1px solid #ccc;
        border-radius: 8px;
    }

    .btn-save {
        background-color: #3e77f8;
        color: white;
        padding: 12px 20px;
        border: none;
        border-radius: 8px;
        cursor: pointer;
    }

    .btn-cancel {
        background-color: #e74c3c;
        color: white;
        padding: 12px 20px;
        border: none;
        border-radius: 8px;
        text-decoration: none;
        margin-left: 10px;
    }

    .btn-save:hover {
        background-color: #234449;
    }

    .btn-cancel:hover {
        background-color: #c0392b;
    }
</style>



