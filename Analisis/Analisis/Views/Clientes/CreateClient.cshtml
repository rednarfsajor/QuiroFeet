@model Analisis.BD.Clientes

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.Title = "Registrar Cliente";
}

<div class="container" style="font-family: 'Poppins', sans-serif;">
    <h1>Registrar Cliente</h1>
    <p>Por favor, completa el formulario para registrar un nuevo cliente</p>

    @using (Html.BeginForm("CreateClient", "Clientes", FormMethod.Post, new { @class = "form" }))
    {
        @Html.AntiForgeryToken()

        <!-- Nombre -->
        <div class="form-group">
            <label for="nombre">Nombre</label>
            @Html.TextBoxFor(model => model.nombre, new { @class = "form-control", placeholder = "Ingrese el nombre", required = "required" })
            @Html.ValidationMessageFor(model => model.nombre)
        </div>

        <!-- Correo -->
        <div class="form-group">
            <label for="correo">Correo Electrónico</label>
            @Html.TextBoxFor(model => model.correo, new { @class = "form-control", placeholder = "Ingrese el correo", type = "email", required = "required" })
            @Html.ValidationMessageFor(model => model.correo)
        </div>

        <!-- Teléfono -->
        <div class="form-group">
            <label for="telefono">Teléfono</label>
            @Html.TextBoxFor(model => model.telefono, new { @class = "form-control", placeholder = "Ingrese el número de teléfono", pattern = "\\d{8}", title = "Debe tener 8 dígitos" })
            @Html.ValidationMessageFor(model => model.telefono)
        </div>

        <!-- Botones -->
        <button type="submit" class="btn btn-primary">Registrar Cliente</button>
        <a href="@Url.Action("ClientIndex", "Clientes")" class="btn btn-secondary">Cancelar</a>
    }

</div>

<style>
    .container {
        max-width: 600px;
        margin: 50px auto;
        background-color: #ffffff;
        padding: 40px;
        border-radius: 12px;
        box-shadow: 0 8px 16px rgba(0, 0, 0, 0.1);
    }

    h1 {
        color: #234449;
        margin-bottom: 20px;
    }

    label {
        font-weight: bold;
    }

    input, select {
        width: 100%;
        padding: 10px;
        margin-bottom: 20px;
        border: 1px solid #ccc;
        border-radius: 8px;
    }

    button, .btn-secondary {
        background-color: #3e77f8;
        border-color: #3e77f8;
        color: white;
        padding: 12px;
        border-radius: 8px;
        font-size: 16px;
        cursor: pointer;
        margin-right: 10px;
        text-decoration: none;
    }

        button:hover, .btn-secondary:hover {
            background-color: #234449;
        }
</style>
