@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.Title = "Ver Empleado";

    var codigo = Request.QueryString["codigo"] ?? "EMP001";

    dynamic profesional = new
    {
        NombreCompleto = "Desconocido",
        Identificacion = "",
        Especialidad = "",
        Telefono = "",
        CorreoElectronico = ""
    };

    if (codigo == "EMP001")
    {
        profesional = new
        {
            NombreCompleto = "Ana María Pérez",
            Identificacion = "12345678-9",
            Especialidad = "Psicología",
            Telefono = "+506 1234 5678",
            CorreoElectronico = "ana.perez@quirofeet.com"
        };
    }
    else if (codigo == "EMP002")
    {
        profesional = new
        {
            NombreCompleto = "Carlos Rojas",
            Identificacion = "87654321-0",
            Especialidad = "Kinesiología",
            Telefono = "+506 8765 4321",
            CorreoElectronico = "carlos.rojas@quirofeet.com"
        };
    }
    else if (codigo == "EMP003")
    {
        profesional = new
        {
            NombreCompleto = "Lucía Gómez",
            Identificacion = "11223344-5",
            Especialidad = "Fonoaudiología",
            Telefono = "+506 3344 5566",
            CorreoElectronico = "lucia.gomez@quirofeet.com"
        };
    }
}


<div class="container mt-4">
    <div class="card shadow-sm">
        <div class="card-header bg-light">
            <h2 class="mb-0 h5"><i class="fas fa-eye me-2"></i> Ver Profesional</h2>
        </div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-6">
                    <label class="form-label fw-bold">Nombre Completo</label>
                    <p class="form-control-plaintext">@profesional.NombreCompleto</p>
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-bold">Identificación</label>
                    <p class="form-control-plaintext">@profesional.Identificacion</p>
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-bold">Especialidad</label>
                    <p class="form-control-plaintext">@profesional.Especialidad</p>
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-bold">Teléfono</label>
                    <p class="form-control-plaintext">@profesional.Telefono</p>
                </div>
                <div class="col-md-12">
                    <label class="form-label fw-bold">Correo Electrónico</label>
                    <p class="form-control-plaintext">@profesional.CorreoElectronico</p>
                </div>
            </div>

            <hr />
            <div class="d-flex justify-content-end">
                <a href="@Url.Action("Index", "Profesionales")" class="btn btn-secondary">
                    <i class="fas fa-arrow-left me-1"></i> Volver
                </a>
            </div>
        </div>
    </div>
</div>
