@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    var codigo = Request.QueryString["codigo"] ?? "EMP001";

    var empleados = new Dictionary<string, dynamic> {
        {
            "EMP001", new {
                NombreCompleto = "Ana María Pérez",
                Identificacion = "12345678-9",
                Especialidad = "Psicología",
                Telefono = "+506 1234 5678",
                CorreoElectronico = "ana.perez@quirofeet.com"
            }
        },
        {
            "EMP002", new {
                NombreCompleto = "Carlos Rojas",
                Identificacion = "87654321-0",
                Especialidad = "Kinesiología",
                Telefono = "+506 8765 4321",
                CorreoElectronico = "carlos.rojas@quirofeet.com"
            }
        },
        {
            "EMP003", new {
                NombreCompleto = "Lucía Gómez",
                Identificacion = "11223344-5",
                Especialidad = "Fonoaudiología",
                Telefono = "+506 3344 5566",
                CorreoElectronico = "lucia.gomez@quirofeet.com"
            }
        }
    };

    var empleado = empleados.ContainsKey(codigo) ? empleados[codigo] : empleados["EMP001"];
}

<div class="container mt-4">
    <div class="card shadow-sm">
        <div class="card-header bg-light">
            <h2 class="mb-0 h5"><i class="fas fa-user-edit me-2"></i> Editar Empleado (@codigo)</h2>
        </div>
        <div class="card-body">
            <form>
                <div class="row g-3">
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Nombre Completo</label>
                        <input type="text" class="form-control" value="@empleado.NombreCompleto">
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Identificación</label>
                        <input type="text" class="form-control" value="@empleado.Identificacion">
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Especialidad</label>
                        <input type="text" class="form-control" value="@empleado.Especialidad">
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Teléfono</label>
                        <input type="text" class="form-control" value="@empleado.Telefono">
                    </div>
                    <div class="col-12 mb-3">
                        <label class="form-label">Correo Electrónico</label>
                        <input type="email" class="form-control" value="@empleado.CorreoElectronico">
                    </div>
                </div>

                <hr />
                <div class="d-flex justify-content-end">
                    <a href="@Url.Action("Index", "Profesionales")" class="btn btn-secondary me-2">
                        <i class="fas fa-arrow-left me-1"></i> Volver
                    </a>
                    <button type="button" class="btn btn-success" disabled>
                        <i class="fas fa-save me-1"></i> Guardar Cambios (vista simulada)
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
