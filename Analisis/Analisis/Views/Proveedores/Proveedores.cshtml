@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.Title = "Proveedores";
}

<div class="container mt-4">
    <div class="card shadow-sm">
        <div class="card-header bg-light d-flex justify-content-between align-items-center">
            <h2 class="mb-0 h5"><i class="fas fa-truck me-2"></i> @ViewBag.Title</h2>
            <div>
                <a href="@Url.Action("RegistrarProveedor", "Proveedores")" class="btn btn-primary btn-sm">
                    <i class="fas fa-plus me-1"></i> Nuevo Proveedor
                </a>
            </div>
        </div>
        <div class="card-body">

            <div id="alertaMensajes" class="alert alert-success alert-dismissible fade show" role="alert" style="display: none;">
                <span id="mensajeTexto"></span>
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>

            <div class="table-responsive">
                <table class="table table-striped table-hover table-bordered table-sm" id="tablaProveedores">
                    <thead class="table-light">
                        <tr>
                            <th>Nombre</th>
                            <th>Contacto</th>
                            <th>Teléfono</th>
                            <th>Correo Electrónico</th>
                            <th>Identificación Fiscal</th>
                            <th>Acciones</th>
                        </tr>
                    </thead>
                    <tbody id="cuerpoTablaProveedores">
                        <!-- Se llenará dinámicamente -->
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function cargarProveedores() {
            const cuerpoTabla = $('#cuerpoTablaProveedores');
            cuerpoTabla.empty();

            const proveedores = [
                { nombre: 'Distribuidora La Tropical', contacto: 'Laura González', telefono: '+506 8701 2345', correo: 'laura@tropical.co.cr', identificacion: '3-101-456789' },
                { nombre: 'Ferretería El Martillo', contacto: 'José Hernández', telefono: '+506 8890 1122', correo: 'jose@martillo.cr', identificacion: '1-115-987654' },
                { nombre: 'Proveedoras Unidas S.A.', contacto: 'María Castro', telefono: '+506 8888 5555', correo: 'mcastro@unidas.cr', identificacion: '3-102-564738' }
            ];

            $.each(proveedores, function (index, proveedor) {
                let fila = `
                    <tr>
                        <td>${proveedor.nombre}</td>
                        <td>${proveedor.contacto}</td>
                        <td>${proveedor.telefono}</td>
                        <td>${proveedor.correo}</td>
                        <td>${proveedor.identificacion}</td>
                        <td>
                            <a href="@Url.Action("VerProveedor", "Proveedores")?identificacion=${proveedor.identificacion}" class="btn btn-sm btn-info me-1">
                                <i class="fas fa-eye"></i> Ver
                            </a>
                            <a href="@Url.Action("EditarProveedor", "Proveedores")?identificacion=${proveedor.identificacion}" class="btn btn-sm btn-warning me-1">
                                <i class="fas fa-edit"></i> Editar
                            </a>
                            <a href="@Url.Action("EliminarProveedor", "Proveedores")?identificacion=${proveedor.identificacion}" class="btn btn-sm btn-danger">
                                <i class="fas fa-trash"></i> Eliminar
                            </a>
                        </td>
                    </tr>`;
                cuerpoTabla.append(fila);
            });
        }

        $(document).ready(function () {
            cargarProveedores();
        });
    </script>
}

