@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.Title = "Ver Proveedor";

    var id = Request.QueryString["identificacion"] ?? "";

    dynamic proveedor = new
    {
        Nombre = "Proveedor desconocido",
        Contacto = "",
        Telefono = "",
        Correo = "",
        Identificacion = ""
    };

    if (id == "3-101-456789")
    {
        proveedor = new
        {
            Nombre = "Distribuidora La Tropical",
            Contacto = "Laura González",
            Telefono = "+506 8701 2345",
            Correo = "laura@tropical.co.cr",
            Identificacion = "3-101-456789"
        };
    }
    else if (id == "1-115-987654")
    {
        proveedor = new
        {
            Nombre = "Ferretería El Martillo",
            Contacto = "José Hernández",
            Telefono = "+506 8890 1122",
            Correo = "jose@martillo.cr",
            Identificacion = "1-115-987654"
        };
    }
    else if (id == "3-102-564738")
    {
        proveedor = new
        {
            Nombre = "Proveedoras Unidas S.A.",
            Contacto = "María Castro",
            Telefono = "+506 8888 5555",
            Correo = "mcastro@unidas.cr",
            Identificacion = "3-102-564738"
        };
    }
}


<div class="container mt-4">
    <div class="card shadow-sm">
        <div class="card-header bg-light">
            <h2 class="mb-0 h5"><i class="fas fa-eye me-2"></i> Ver Proveedor</h2>
        </div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-6">
                    <label class="form-label fw-bold">Nombre</label>
                    <p class="form-control-plaintext">@proveedor.Nombre</p>
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-bold">Persona de Contacto</label>
                    <p class="form-control-plaintext">@proveedor.Contacto</p>
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-bold">Teléfono</label>
                    <p class="form-control-plaintext">@proveedor.Telefono</p>
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-bold">Correo Electrónico</label>
                    <p class="form-control-plaintext">@proveedor.Correo</p>
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-bold">Identificación Fiscal</label>
                    <p class="form-control-plaintext">@proveedor.Identificacion</p>
                </div>
            </div>

            <hr />
            <div class="d-flex justify-content-end">
                <a href="@Url.Action("Index", "Proveedores")" class="btn btn-secondary">
                    <i class="fas fa-arrow-left me-1"></i> Volver
                </a>
            </div>
        </div>
    </div>
</div>
