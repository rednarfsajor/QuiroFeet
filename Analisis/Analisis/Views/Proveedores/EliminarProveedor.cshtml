@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.Title = "Eliminar Proveedor";

    var id = Request.QueryString["identificacion"] ?? "";

    dynamic proveedor = new
    {
        Nombre = "Proveedor desconocido",
        Contacto = "",
        Telefono = "",
        Correo = "",
        Identificacion = ""
    };

    if (id == "3-101-456789")
    {
        proveedor = new
        {
            Nombre = "Distribuidora La Tropical",
            Contacto = "Laura González",
            Telefono = "+506 8701 2345",
            Correo = "laura@tropical.co.cr",
            Identificacion = "3-101-456789"
        };
    }
    else if (id == "1-115-987654")
    {
        proveedor = new
        {
            Nombre = "Ferretería El Martillo",
            Contacto = "José Hernández",
            Telefono = "+506 8890 1122",
            Correo = "jose@martillo.cr",
            Identificacion = "1-115-987654"
        };
    }
    else if (id == "3-102-564738")
    {
        proveedor = new
        {
            Nombre = "Proveedoras Unidas S.A.",
            Contacto = "María Castro",
            Telefono = "+506 8888 5555",
            Correo = "mcastro@unidas.cr",
            Identificacion = "3-102-564738"
        };
    }
}

<div class="container mt-4">
    <div class="card border-danger shadow-sm">
        <div class="card-header bg-danger text-white">
            <h2 class="mb-0 h5"><i class="fas fa-trash me-2"></i> Eliminar Proveedor</h2>
        </div>
        <div class="card-body">
            <p class="text-danger fs-5">
                <i class="fas fa-exclamation-triangle me-2"></i>
                ¿Estás seguro que deseas eliminar al siguiente proveedor?
            </p>

            <ul class="list-group mb-3">
                <li class="list-group-item"><strong>Nombre:</strong> @proveedor.Nombre</li>
                <li class="list-group-item"><strong>Contacto:</strong> @proveedor.Contacto</li>
                <li class="list-group-item"><strong>Teléfono:</strong> @proveedor.Telefono</li>
                <li class="list-group-item"><strong>Correo:</strong> @proveedor.Correo</li>
                <li class="list-group-item"><strong>Identificación Fiscal:</strong> @proveedor.Identificacion</li>
            </ul>

            <div class="d-flex justify-content-end">
                <a href="@Url.Action("Index", "Proveedores")" class="btn btn-secondary me-2">
                    <i class="fas fa-times me-1"></i> Cancelar
                </a>
                <button class="btn btn-danger" disabled>
                    <i class="fas fa-trash-alt me-1"></i> Eliminar Proveedor
                </button>
            </div>
        </div>
    </div>
</div>
