@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.Title = "Editar Proveedor";

    var id = Request.QueryString["identificacion"] ?? "";

    dynamic proveedor = new
    {
        Nombre = "Proveedor desconocido",
        Contacto = "",
        Telefono = "",
        Correo = "",
        Identificacion = ""
    };

    if (id == "3-101-456789")
    {
        proveedor = new
        {
            Nombre = "Distribuidora La Tropical",
            Contacto = "Laura González",
            Telefono = "+506 8701 2345",
            Correo = "laura@tropical.co.cr",
            Identificacion = "3-101-456789"
        };
    }
    else if (id == "1-115-987654")
    {
        proveedor = new
        {
            Nombre = "Ferretería El Martillo",
            Contacto = "José Hernández",
            Telefono = "+506 8890 1122",
            Correo = "jose@martillo.cr",
            Identificacion = "1-115-987654"
        };
    }
    else if (id == "3-102-564738")
    {
        proveedor = new
        {
            Nombre = "Proveedoras Unidas S.A.",
            Contacto = "María Castro",
            Telefono = "+506 8888 5555",
            Correo = "mcastro@unidas.cr",
            Identificacion = "3-102-564738"
        };
    }
}

<div class="container mt-4">
    <div class="card shadow-sm">
        <div class="card-header bg-light">
            <h2 class="mb-0 h5"><i class="fas fa-edit me-2"></i> Editar Proveedor</h2>
        </div>
        <div class="card-body">
            <form>
                <div class="row g-3">
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Nombre</label>
                        <input type="text" class="form-control" value="@proveedor.Nombre">
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Persona de Contacto</label>
                        <input type="text" class="form-control" value="@proveedor.Contacto">
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Teléfono</label>
                        <input type="text" class="form-control" value="@proveedor.Telefono">
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Correo Electrónico</label>
                        <input type="email" class="form-control" value="@proveedor.Correo">
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Identificación Fiscal</label>
                        <input type="text" class="form-control" value="@proveedor.Identificacion">
                    </div>
                </div>

                <hr />
                <div class="d-flex justify-content-end">
                    <a href="@Url.Action("Index", "Proveedores")" class="btn btn-secondary me-2">
                        <i class="fas fa-arrow-left me-1"></i> Volver
                    </a>
                    <button type="button" class="btn btn-success" disabled>
                        <i class="fas fa-save me-1"></i> Guardar Cambios (vista simulada)
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
